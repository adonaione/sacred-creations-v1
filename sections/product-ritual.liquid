<section class="sacred-ritual-section" style="padding: 100px 0; text-align: center;">
  <div class="page-width">
    <h2 style="font-style: italic; font-weight: 300;">The Anointing Ritual</h2>
    <div class="ritual-grid" style="display: flex; justify-content: space-around; margin-top: 50px;">
      
      <div class="ritual-step">
        <span class="step-num">01</span>
        <p><strong>WARM</strong><br>3-5 drops in palms.</p>
      </div>

      <div class="ritual-step">
        <span class="step-num">02</span>
        <p><strong>INHALE</strong><br>Breathe the Frankincense.</p>
      </div>

      <div class="ritual-step">
        <span class="step-num">03</span>
        <p><strong>ANOINT</strong><br>Press into damp skin.</p>
      </div>

    </div>
    <p class="affirmation" style="margin-top: 60px; letter-spacing: 0.1em;">
      <em>"I am grounded. I am pure. I am golden."</em>
    </p>
  </div>
</section>

<style>
  .step-num { font-size: 0.8rem; color: var(--gold-accent); display: block; margin-bottom: 10px; }
  .ritual-step p { font-size: 0.9rem; text-transform: uppercase; letter-spacing: 1px; }
</style>

